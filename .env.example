# HTTP server
PORT=8080
HOST=0.0.0.0

# Paths (optional overrides)
# CONFIG_PATH=./config/config.json
# PLUGINS_DIR=./plugins

# Secrets referenced from plugins as {{secret.NAME}} can be provided either
# here (as SECRET_<NAME>) or in config/secrets.json.
# Example: a plugin using {{secret.openweather}} reads SECRET_OPENWEATHER.
# SECRET_OPENWEATHER=your-api-key

# --- Admin auth ---
# Quick-start credentials (hashed at load). Otherwise use: npm run set-password
# ADMIN_USER=admin
# ADMIN_PASSWORD=change-me
# Stable secret so sessions survive restarts (else one is generated each boot).
# AUTH_SESSION_SECRET=a-long-random-string
# Override the OAuth2 client secret without putting it in config/auth.json.
# OAUTH2_CLIENT_SECRET=your-client-secret
